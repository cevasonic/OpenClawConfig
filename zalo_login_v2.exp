#!/usr/bin/expect -f

set timeout 180
set password "nsM7H_!$?!Ye"
set hostname "180.93.137.94"
set user "root"

spawn ssh -tt -o StrictHostKeyChecking=no $user@$hostname "HOME=/opt/openclaw openclaw channels login --channel zalouser --verbose 2>&1"
expect {
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    "*assword:*" {
        send "$password\r"
        exp_continue
    }
    eof
}
